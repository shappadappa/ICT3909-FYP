---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main class="bg-cream flex h-[calc(100vh-69px)] flex-col items-center justify-center gap-6">
		<h1 class="text-4xl font-bold text-gray-800">Error 404: Page Not Found</h1>

		<p>
			The page you were not looking for was not found. Go back to the homepage <a
				class="text-blue-500 underline"
				href="/">here</a
			>.
		</p>
	</main>
</Layout>
