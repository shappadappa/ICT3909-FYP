---
import { MealPlan, Pantry } from "../components";
import Layout from "../layouts/Layout.astro";
import { breakfastMeals, lunchMeals, dinnerMeals, pantryIngredients } from "../mock.const";
---

<Layout>
	<main class="bg-cream flex h-[calc(100vh-69px)] gap-5 p-6">
		<MealPlan breakfast={breakfastMeals} lunch={lunchMeals} dinner={dinnerMeals} />
		<Pantry pantryIngredients={pantryIngredients} />
	</main>
</Layout>
