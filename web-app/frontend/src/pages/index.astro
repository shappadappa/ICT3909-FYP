---
import { MealPlan, OnboardingModal, Pantry } from "../components";
import Layout from "../layouts/Layout.astro";

const isOnboarded = Astro.cookies.get("onboarded")?.value === "true";

export const prerender = false;
---

<Layout>
	<main class="bg-cream flex h-[calc(100vh-69px)] gap-5 p-6">
		<MealPlan client:load />
		<Pantry client:load />

		{!isOnboarded && <OnboardingModal client:load />}
	</main>
</Layout>
