---
import { Header, Snackbar } from "../components";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<meta name="description" content="An AI-powered meal planning app that generates personalised weekly meal plans to minimise food waste, stay within budget, and meet your dietary goals." />
		<meta name="robots" content="noindex, nofollow" />
		<meta name="theme-color" content="#4F7A47" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content="Smart, Personalised and Efficient Meal Planning: Using AI to Combat Food Waste" />
		<meta property="og:description" content="An AI-powered meal planning app that generates personalised weekly meal plans to minimise food waste, stay within budget, and meet your dietary goals." />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content="Smart, Personalised and Efficient Meal Planning: Using AI to Combat Food Waste" />
