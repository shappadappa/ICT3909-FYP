---
import type { Recipe } from "../types";
import Badge from "./Badge";
import Modal from "./Modal.astro";

interface Props {
	recipe: Recipe;
	isError?: boolean;
}

const { recipe, isError } = Astro.props;

const TAG_STYLES: Record<string, string> = {
	GLUTEN_FREE: "bg-amber-50 text-amber-700 border-amber-200",
	LACTOSE_FREE: "bg-blue-50 text-blue-700 border-blue-200",
	VEGETARIAN: "bg-green-50 text-green-700 border-green-200",
	VEGAN: "bg-emerald-50 text-emerald-700 border-emerald-200",
};

const TAG_LABELS: Record<string, string> = {
	GLUTEN_FREE: "Gluten Free",
	LACTOSE_FREE: "Lactose Free",
	VEGETARIAN: "Vegetarian",
	VEGAN: "Vegan",
};

console.log(recipe.name, isError);
---

<Modal id={recipe.id} title="Recipe Details">
	{
		isError ? (
			<div class="py-4 text-center text-sm text-red-500">Failed to load recipe details.</div>
		) : (
			<div class="max-h-[65vh] space-y-4 overflow-y-auto pr-4">
				<div>
					<h3 class="text-base font-semibold text-gray-800">{recipe.name}</h3>
					<div class="mt-1.5 flex flex-wrap gap-1">
						{recipe.dietaryTags?.map((tag) => (
							<Badge label={TAG_LABELS[tag] ?? tag} additionalClasses={TAG_STYLES[tag]} />
						))}
					</div>
				</div>

				<div class="grid grid-cols-4 gap-2 rounded-lg bg-gray-50 p-3 text-center text-xs">
					{[
						{ label: "Calories", value: Math.round(recipe.nutritionalInformation.calories), unit: "kcal" },
						{ label: "Protein", value: recipe.nutritionalInformation.protein.toFixed(1), unit: "g" },
						{ label: "Carbs", value: recipe.nutritionalInformation.carbohydrates.toFixed(1), unit: "g" },
						{ label: "Fat", value: recipe.nutritionalInformation.fat.toFixed(1), unit: "g" },
					].map(({ label, value, unit }) => (
						<div>
							<p class="font-semibold text-gray-800">
								{value}
								<span class="font-normal text-gray-400">{unit}</span>
							</p>
							<p class="mt-0.5 text-gray-500">{label}</p>
						</div>
					))}
				</div>

				<div>
					<h4 class="mb-1.5 text-xs font-semibold tracking-wide text-gray-400 uppercase">Ingredients</h4>
					<ul class="space-y-1 text-sm text-gray-700">
						{recipe.ingredients.map(({ ingredient, quantity }) => (
							<li class="flex justify-between gap-4">
								<span class="capitalize">{ingredient}</span>
								<span class="shrink-0 text-gray-400">
									{quantity % 1 === 0 ? quantity : quantity.toFixed(1)}g
								</span>
							</li>
						))}
					</ul>
				</div>

				<div>
					<h4 class="mb-1.5 text-xs font-semibold tracking-wide text-gray-400 uppercase">Instructions</h4>
					<div class="divide-y divide-gray-100 text-sm leading-relaxed text-gray-700">
						{recipe.instructions.map((step) => (
							<p class="py-2">{step}</p>
						))}
					</div>
				</div>
			</div>
		)
	}
</Modal>
