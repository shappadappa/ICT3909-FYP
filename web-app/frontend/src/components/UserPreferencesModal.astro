---
import Modal from "./Modal.astro";
---

<Modal id="user-preferences-modal" title="User Preferences">
	<form class="flex flex-col gap-5">
		<fieldset class="flex flex-col gap-2">
			<legend class="mb-1 text-xs font-semibold tracking-wide text-gray-400 uppercase"
				>Dietary restrictions</legend
			>

			<label
				class="hover:bg-sage-50 flex cursor-pointer items-center gap-3 rounded-lg border border-gray-100 px-3 py-2.5"
			>
				<input
					type="checkbox"
					name="gluten-intolerant"
					id="gluten-intolerant"
					class="accent-sage-600 h-4 w-4 cursor-pointer rounded"
				/>
				<span class="text-sm text-gray-700">Gluten-intolerant / Celiac</span>
			</label>

			<label
				class="hover:bg-sage-50 flex cursor-pointer items-center gap-3 rounded-lg border border-gray-100 px-3 py-2.5"
			>
				<input
					type="checkbox"
					name="lactose-intolerant"
					id="lactose-intolerant"
					class="accent-sage-600 h-4 w-4 cursor-pointer rounded"
				/>
				<span class="text-sm text-gray-700">Lactose-intolerant</span>
			</label>
		</fieldset>

		<fieldset class="flex flex-col gap-3">
			<legend class="mb-1 text-xs font-semibold tracking-wide text-gray-400 uppercase">Daily targets</legend>

			<div class="flex flex-col gap-1">
				<label for="calories" class="text-sm font-medium text-gray-600">Caloric intake</label>
				<div class="relative">
					<input
						type="number"
						name="calories"
						id="calories"
						min="0"
						placeholder="2000"
						class="focus:border-sage-400 w-full rounded-lg border border-gray-200 bg-gray-50 py-2 pr-12 pl-3 text-sm text-gray-800 outline-none focus:bg-white"
					/>
					<span class="pointer-events-none absolute top-1/2 right-3 -translate-y-1/2 text-xs text-gray-400"
						>kcal</span
					>
				</div>
			</div>

			<div class="flex flex-col gap-1">
				<label for="protein" class="text-sm font-medium text-gray-600">Protein intake</label>
				<div class="relative">
					<input
						type="number"
						name="protein"
						id="protein"
						min="0"
						placeholder="50"
						class="focus:border-sage-400 w-full rounded-lg border border-gray-200 bg-gray-50 py-2 pr-12 pl-3 text-sm text-gray-800 outline-none focus:bg-white"
					/>
					<span class="pointer-events-none absolute top-1/2 right-3 -translate-y-1/2 text-xs text-gray-400"
						>g</span
					>
				</div>
			</div>
		</fieldset>

		<button
			type="submit"
			class="bg-sage-600 hover:bg-sage-800 mt-1 w-full rounded-lg py-2 text-sm font-medium text-white transition-colors"
		>
			Save preferences
		</button>
	</form>
</Modal>

<script>
	const STORAGE_KEY = "user-preferences";

	const form = document.querySelector<HTMLFormElement>("form");

	const validateFields = (calories: string | null, protein: string | null) => {
		if (!calories) {
			return "Caloric intake is required.";
		}

		if (!protein) {
			return "Protein intake is required.";
		}

		if (isNaN(Number(calories)) || Number(calories) < 0) {
			return "Caloric intake must be a non-negative number.";
		}

		if (isNaN(Number(protein)) || Number(protein) < 0) {
			return "Protein intake must be a non-negative number.";
		}

		return null;
	};

	// Load saved preferences into the form
	const savedPrefs = localStorage.getItem(STORAGE_KEY);
	if (savedPrefs) {
		const prefs = JSON.parse(savedPrefs);
		const caloriesInput = document.getElementById("calories") as HTMLInputElement;
		const proteinInput = document.getElementById("protein") as HTMLInputElement;
		const glutenInput = document.getElementById("gluten-intolerant") as HTMLInputElement;
		const lactoseInput = document.getElementById("lactose-intolerant") as HTMLInputElement;

		if (caloriesInput) caloriesInput.value = prefs.calories ?? "";
		if (proteinInput) proteinInput.value = prefs.protein ?? "";
		if (glutenInput) glutenInput.checked = prefs.glutenIntolerant ?? false;
		if (lactoseInput) lactoseInput.checked = prefs.lactoseIntolerant ?? false;
	}

	form?.addEventListener("submit", (e) => {
		e.preventDefault();

		const formData = new FormData(form);
		const calories = formData.get("calories") as string | null;
		const protein = formData.get("protein") as string | null;

		const errorMsg = validateFields(calories, protein);

		if (errorMsg) {
			window.showSnackbar(errorMsg, "error");
			return;
		}

		const prefs = {
			calories: Number(calories),
			protein: Number(protein),
			glutenIntolerant: formData.has("gluten-intolerant"),
			lactoseIntolerant: formData.has("lactose-intolerant"),
		};

		localStorage.setItem(STORAGE_KEY, JSON.stringify(prefs));
		window.closeModal("user-preferences-modal");
		window.showSnackbar("Preferences saved successfully!", "success");
	});
</script>
