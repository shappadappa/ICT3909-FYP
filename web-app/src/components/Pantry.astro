---
import type { Ingredient } from "../types";
import { IngredientGroupEnum } from "../types/IngredientGroup";

interface Props {
	pantryIngredients: Ingredient[];
}

const { pantryIngredients } = Astro.props;

const groupedIngredients = pantryIngredients.reduce(
	(groups, ingredient) => {
		const group = ingredient.group;

		if (!groups[group]) {
			groups[group] = [];
		}

		groups[group].push(ingredient);
		return groups;
	},
	{} as Record<IngredientGroupEnum, Ingredient[]>
);

const IngredientGroupLabels: Record<IngredientGroupEnum, string> = {
	[IngredientGroupEnum.PRODUCE]: "🥦 Produce",
	[IngredientGroupEnum.PROTEINS]: "🥩 Proteins",
	[IngredientGroupEnum.GRAINS]: "🌾 Grains",
	[IngredientGroupEnum.DAIRY]: "🧀 Dairy",
	[IngredientGroupEnum.CONDIMENTS]: "🧂 Condiments",
};
---

<aside class="flex w-72 shrink-0 flex-col">
	<div class="mb-4 flex items-center justify-between">
		<h2 class="font-display text-walnut-800 text-lg font-semibold">Pantry</h2>
		<button
			class="text-sage-600 hover:text-sage-800 bg-sage-50 border-sage-100 rounded-lg border px-2.5 py-1 text-xs font-medium transition-colors"
			>+ Add Item</button
		>
	</div>

	<div class="border-walnut-100 flex flex-1 flex-col overflow-hidden rounded-2xl border bg-white">
		<!-- Search -->
		<div class="border-walnut-50 border-b p-3">
			<div class="relative">
				<svg
					class="text-walnut-300 absolute top-1/2 left-3 h-3.5 w-3.5 -translate-y-1/2"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path></svg
				>
				<input
					type="text"
					placeholder="Search pantry…"
					class="bg-parchment border-walnut-100 text-walnut-700 placeholder-walnut-300 focus:ring-sage-300 w-full rounded-lg border py-2 pr-3 pl-8 text-xs focus:ring-1 focus:outline-none"
				/>
			</div>
		</div>

		<div class="flex-1 space-y-4 overflow-y-auto p-3">
			{
				(Object.entries(IngredientGroupLabels) as [IngredientGroupEnum, string][])
					.filter(([group]) => groupedIngredients[group]?.length > 0)
					.map(([group, label]) => (
						<div>
							<p class="text-walnut-400 mb-2 px-1 text-xs font-semibold tracking-wider uppercase">
								{label}
							</p>
							<div class="space-y-1">
								{groupedIngredients[group].map((ingredient) => (
									<div class="pantry-item flex cursor-pointer items-center justify-between rounded-lg px-3 py-2 transition-colors">
										<div>
											<p class="text-walnut-700 text-xs font-medium">{ingredient.name}</p>
											<p class="text-walnut-400 text-xs">{ingredient.description}</p>
										</div>
										<span
											class={`badge-${ingredient.status === "OK" ? "ok" : "low"} rounded-full px-2 py-0.5 text-xs font-medium`}
										>
											{ingredient.status}
										</span>
									</div>
								))}
							</div>
						</div>
					))
			}
		</div>

		<!-- Pantry footer -->
		<div class="border-walnut-100 bg-parchment flex items-center justify-between border-t px-4 py-3">
			<div class="flex gap-3">
				<span class="text-walnut-500 text-xs"
					><span class="text-terra-600 font-semibold">6</span> low stock</span
				>
				<span class="text-walnut-500 text-xs"><span class="text-sage-600 font-semibold">13</span> stocked</span>
			</div>
			<button
				class="text-terra-600 hover:text-terra-800 bg-terra-50 border-terra-100 rounded-lg border px-2.5 py-1 text-xs font-medium transition-colors"
				>Shopping List →</button
			>
		</div>
	</div>
</aside>
